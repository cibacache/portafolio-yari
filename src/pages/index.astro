---
const title = "Yaritza Mondaca | Contenido Audiovisual & Divulgación";
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --zinc-950: #09090b;
            --zinc-900: #18181b;
            --zinc-800: #27272a;
            --zinc-700: #3f3f46;
            --zinc-600: #52525b;
            --zinc-400: #a1a1aa;
            --zinc-300: #d4d4d8;
            --zinc-100: #f4f4f5;
            --zinc-50: #fafafa;
            
            --emerald-500: #10b981;
            --emerald-400: #34d399;
            
            --font-sans: 'Geist', -apple-system, system-ui, sans-serif;
            --font-mono: 'Geist Mono', 'JetBrains Mono', monospace;
            
            --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
            --ease-in-out: cubic-bezier(0.77, 0, 0.175, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            background-color: var(--zinc-950);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: var(--font-sans);
            color: var(--zinc-100);
            line-height: 1.6;
            background: var(--zinc-950);
        }

        /* Header con glassmorphism refinado */
        header {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            padding: 1.25rem 2rem;
            background: rgba(9, 9, 11, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(39, 39, 42, 0.5);
            transition: all 180ms var(--ease-out);
        }

        header.scrolled {
            padding: 0.875rem 2rem;
            background: rgba(9, 9, 11, 0.95);
            border-bottom-color: rgba(39, 39, 42, 0.8);
        }

        .header-container {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-weight: 600;
            font-size: 1.125rem;
            letter-spacing: -0.02em;
            color: var(--zinc-50);
            text-decoration: none;
            transition: color 160ms var(--ease-out);
        }

        .logo:hover {
            color: var(--emerald-400);
        }

        nav {
            display: flex;
            gap: 2rem;
        }

        nav a {
            font-size: 0.9375rem;
            font-weight: 500;
            color: var(--zinc-400);
            text-decoration: none;
            letter-spacing: -0.01em;
            transition: color 160ms var(--ease-out);
            position: relative;
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -0.25rem;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--emerald-400);
            transition: width 200ms var(--ease-out);
        }

        nav a:hover {
            color: var(--zinc-100);
        }

        nav a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        #inicio {
            position: relative;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: var(--zinc-950);
        }

        .video-background {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .video-background::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, 
                rgba(9, 9, 11, 0.4) 0%, 
                rgba(9, 9, 11, 0.7) 50%,
                rgba(9, 9, 11, 0.9) 100%);
            z-index: 2;
        }

        .video-background iframe {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 177.77vh;
            height: 100vh;
            min-width: 100%;
            min-height: 100%;
            transform: translate(-50%, -50%);
            opacity: 0.5;
        }

        .hero-content {
            position: relative;
            z-index: 3;
            max-width: 1200px;
            padding: 0 2rem;
            text-align: center;
        }

        .hero-title {
            font-size: clamp(2.5rem, 8vw, 6rem);
            font-weight: 600;
            letter-spacing: -0.04em;
            line-height: 1;
            margin-bottom: 1.5rem;
            color: var(--zinc-50);
        }

        .hero-subtitle {
            font-size: clamp(1rem, 2vw, 1.375rem);
            font-weight: 400;
            line-height: 1.5;
            color: var(--zinc-300);
            max-width: 65ch;
            margin: 0 auto;
            letter-spacing: -0.01em;
        }

        .scroll-indicator {
            position: absolute;
            bottom: 3rem;
            left: 50%;
            transform: translateX(-50%);
            z-index: 3;
            width: 1px;
            height: 60px;
            background: linear-gradient(180deg, 
                transparent 0%, 
                var(--emerald-400) 50%, 
                transparent 100%);
            animation: scroll-pulse 2s var(--ease-in-out) infinite;
        }

        @keyframes scroll-pulse {
            0%, 100% { opacity: 0.3; transform: translateX(-50%) translateY(0); }
            50% { opacity: 1; transform: translateX(-50%) translateY(10px); }
        }

        /* Sección base */
        section {
            padding: 6rem 2rem;
            max-width: 1400px;
            margin: 0 auto;
        }

        section:first-of-type {
            padding-top: 0;
        }

        .section-title {
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 600;
            letter-spacing: -0.03em;
            line-height: 1;
            margin-bottom: 4rem;
            color: var(--zinc-50);
        }

        /* Proyectos Section */
        #proyectos {
            background: linear-gradient(180deg, 
                var(--zinc-950) 0%, 
                var(--zinc-900) 50%,
                var(--zinc-950) 100%);
        }

        .proyectos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 380px), 1fr));
            gap: 2.5rem;
        }

        .proyecto-card {
            background: rgba(39, 39, 42, 0.3);
            border-radius: 16px;
            border: 1px solid rgba(63, 63, 70, 0.5);
            overflow: hidden;
            transition: all 200ms var(--ease-out);
        }

        .proyecto-card:hover {
            transform: translateY(-8px);
            border-color: var(--emerald-500);
            box-shadow: 0 24px 48px rgba(16, 185, 129, 0.12);
        }

        .proyecto-video {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            background: var(--zinc-900);
            overflow: hidden;
        }

        .proyecto-video iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .proyecto-info {
            padding: 2rem;
        }

        .proyecto-title {
            font-size: 1.5rem;
            font-weight: 600;
            letter-spacing: -0.02em;
            margin-bottom: 0.75rem;
            color: var(--zinc-50);
        }

        .proyecto-descripcion {
            font-size: 0.9375rem;
            line-height: 1.7;
            color: var(--zinc-400);
            letter-spacing: -0.01em;
        }

        /* Sobre mí Section */
        #sobre-mi {
            background: var(--zinc-950);
        }

        .sobre-mi-grid {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 5rem;
            align-items: start;
        }

        .sobre-mi-text p {
            font-size: 1rem;
            line-height: 1.7;
            color: var(--zinc-300);
            margin-bottom: 1.5rem;
            max-width: 65ch;
            letter-spacing: -0.01em;
        }

        .sobre-mi-text p.highlight {
            font-size: 1.25rem;
            font-weight: 500;
            color: var(--zinc-100);
            margin-bottom: 2rem;
        }

        .btn-cv {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.875rem 1.75rem;
            margin-top: 1.5rem;
            background: var(--emerald-500);
            color: var(--zinc-950);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9375rem;
            border-radius: 12px;
            transition: all 160ms var(--ease-out);
            border: 1px solid var(--emerald-500);
        }

        .btn-cv:hover {
            background: var(--emerald-400);
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(16, 185, 129, 0.2);
        }

        .btn-cv:active {
            transform: translateY(0) scale(0.98);
        }

        /* Foto estática (solo foto1) */
        .profile-photo {
            position: relative;
            width: 100%;
            aspect-ratio: 4 / 3;
            border-radius: 16px;
            overflow: hidden;
            background: var(--zinc-900);
            border: 1px solid rgba(63, 63, 70, 0.5);
        }

        .profile-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        /* Contacto Section */
        #contacto {
            background: var(--zinc-900);
            border-top: 1px solid rgba(63, 63, 70, 0.5);
            text-align: center;
        }

        .contacto-content h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 600;
            letter-spacing: -0.03em;
            margin-bottom: 1rem;
            color: var(--zinc-50);
        }

        .contacto-nombre {
            font-size: 1.5rem;
            font-weight: 500;
            color: var(--zinc-300);
            margin-bottom: 2rem;
        }

        .contacto-links {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            align-items: center;
        }

        .contacto-link {
            font-size: 1.0625rem;
            color: var(--zinc-400);
        }

        .contacto-link a {
            color: var(--emerald-400);
            text-decoration: none;
            font-weight: 500;
            transition: color 160ms var(--ease-out);
            position: relative;
        }

        .contacto-link a::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 0;
            height: 1px;
            background: var(--emerald-400);
            transition: width 200ms var(--ease-out);
        }

        .contacto-link a:hover {
            color: var(--emerald-300);
        }

        .contacto-link a:hover::after {
            width: 100%;
        }

        .footer-copyright {
            margin-top: 3rem;
            padding-top: 2rem;
            border-top: 1px solid rgba(63, 63, 70, 0.3);
            font-size: 0.875rem;
            color: var(--zinc-600);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .header-container {
                flex-direction: column;
                gap: 1rem;
            }

            nav {
                gap: 1.5rem;
            }

            nav a {
                font-size: 0.875rem;
            }

            section {
                padding: 4rem 1.5rem;
            }

            .section-title {
                margin-bottom: 2.5rem;
            }

            .hero-title {
                font-size: clamp(2rem, 10vw, 3rem);
            }

            .sobre-mi-grid {
                grid-template-columns: 1fr;
                gap: 3rem;
            }

            .proyectos-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <header id="header">
        <div class="header-container">
            <a href="#inicio" class="logo">Yaritza Mondaca</a>
            <nav>
                <a href="#inicio">Inicio</a>
                <a href="#proyectos">Proyectos</a>
                <a href="#sobre-mi">Sobre mí</a>
                <a href="#contacto">Contacto</a>
            </nav>
        </div>
    </header>

    <section id="inicio">
        <div class="video-background">
            <iframe src="https://www.youtube.com/embed/4pi-T4LH3cc?autoplay=1&mute=1&loop=1&playlist=4pi-T4LH3cc&controls=0&rel=0&modestbranding=1&iv_load_policy=3"
                    allow="autoplay; encrypted-media"
                    allowfullscreen></iframe>
        </div>
        <div class="hero-content">
            <h1 class="hero-title">Contenido Audiovisual & Divulgación</h1>
            <p class="hero-subtitle">Transformando ideas complejas en narrativas visuales potentes para la comunicación científica y educativa</p>
        </div>
        <div class="scroll-indicator"></div>
    </section>

    <section id="proyectos">
        <h2 class="section-title">Proyectos destacados</h2>
        <div class="proyectos-grid">
            <article class="proyecto-card">
                <div class="proyecto-video">
                    <iframe src="https://www.youtube.com/embed/BrDQabOUr4E" allowfullscreen title="Teoría de Lycal Radio"></iframe>
                </div>
                <div class="proyecto-info">
                    <h3 class="proyecto-title">Teoría de Lycal Radio</h3>
                    <p class="proyecto-descripcion">Dirección, locución y montaje audiovisual del podcast La Teoría de Lycal Radio, espacio de conversación sobre el desarrollo científico tecnológico de la Universidad de La Serena, emitido en la Radio Userena y @divulgacionuserena en YouTube.</p>
                </div>
            </article>

            <article class="proyecto-card">
                <div class="proyecto-video">
                    <iframe src="https://www.youtube.com/embed/2t5Kt0qk4ow" allowfullscreen title="Soli, la cazadora del desierto"></iframe>
                </div>
                <div class="proyecto-info">
                    <h3 class="proyecto-title">Soli, la cazadora del desierto</h3>
                    <p class="proyecto-descripcion">Locución y montaje audiovisual del audiolibro.</p>
                </div>
            </article>

            <article class="proyecto-card">
                <div class="proyecto-video">
                    <iframe src="https://www.youtube.com/embed/A7o6tiGTN14" allowfullscreen title="Nivel Curioso CL"></iframe>
                </div>
                <div class="proyecto-info">
                    <h3 class="proyecto-title">Nivel Curioso CL</h3>
                    <p class="proyecto-descripcion">Creadora del canal de datos curiosos con enfoque en la divulgación del conocimiento.</p>
                </div>
            </article>
        </div>
    </section>

    <section id="sobre-mi">
        <h2 class="section-title">Sobre mí</h2>
        <div class="sobre-mi-grid">
            <div class="sobre-mi-text">
                <p class="highlight">Periodista y especialista en generación de contenidos audiovisuales</p>
                <p>Me dedico a la creación de contenido audiovisual y fotografía con un enfoque en la divulgación del conocimiento. Mi objetivo es transformar ideas y conceptos complejos en relatos narrativos visuales potentes y atractivos.</p>
                <p>Cuento con más de 10 años de experiencia en generación de contenidos audiovisuales para medios digitales. Manejo redacción periodística, comunicación científica, escritura creativa, guión audiovisual, locución, equipos audiovisuales y edición de video.</p>
                <a href="/curriculum.pdf" target="_blank" class="btn-cv">
                    <span>Descargar Currículum</span>
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M8 12L8 4M8 12L5 9M8 12L11 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </a>
            </div>

            <div class="profile-photo">
                <img src="/foto1.png" alt="Yaritza Mondaca - Periodista y especialista en contenidos audiovisuales">
            </div>
        </div>
    </section>

    <section id="contacto">
        <div class="contacto-content">
            <h2>Contacto</h2>
            <p class="contacto-nombre">Yaritza Mondaca Rodríguez</p>
            <div class="contacto-links">
                <p class="contacto-link">Correo: <a href="mailto:ymondaca1@gmail.com">ymondaca1@gmail.com</a></p>
                <p class="contacto-link">Instagram: <a href="https://instagram.com/ymondaca_1" target="_blank" rel="noopener noreferrer">@ymondaca_1</a></p>
            </div>
            <p class="footer-copyright">© 2026 Yaritza Mondaca. Todos los derechos reservados.</p>
        </div>
    </section>

    <script>
        // Header scroll effect
        if (typeof window !== 'undefined') {
            const header = document.getElementById('header');
            
            window.addEventListener('scroll', () => {
                if (window.scrollY > 100) {
                    header?.classList.add('scrolled');
                } else {
                    header?.classList.remove('scrolled');
                }
            });

            // Smooth scroll con offset para header fijo
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = anchor.getAttribute('href');
                    if (!targetId) return;
                    
                    const target = document.querySelector(targetId);
                    if (target) {
                        const headerHeight = header?.offsetHeight || 80;
                        const targetPosition = target.offsetTop - headerHeight;
                        
                        window.scrollTo({
                            top: targetPosition,
                            behavior: 'smooth'
                        });
                    }
                });
            });
        }
    </script>
</body>
</html>
